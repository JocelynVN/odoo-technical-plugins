# pylint config that runs Odoo's REAL test_lint checks, using Odoo's own
# checker plugins (the ones in odoo/addons/test_lint/tests). This is exactly
# what Odoo's test_pylint.py runs — same plugins, same enabled messages — so
# you get Odoo's authentic SQL-injection / gettext / unlink-override checks,
# not a reimplementation.
#
# Requirements: pylint must be installed (Odoo does NOT ship it in
# requirements.txt, and Odoo's own test silently skips when it's missing):
#     pip install "pylint>=3.0"
#
# Run it from a place where the `odoo` package is importable (i.e. your Odoo
# dev environment). The init-hook below finds Odoo's checker modules next to
# the installed odoo package and puts them on sys.path so load-plugins can
# import them by name — the same mechanism test_pylint.py uses.
#
#     pylint --rcfile=pylintrc path/to/your_module
#
# If `odoo` is NOT importable but you have the source tree, point pylint at the
# checkers manually instead of relying on the init-hook:
#     PYTHONPATH="/path/to/odoo/odoo/addons/test_lint/tests:$PYTHONPATH" \
#         pylint --rcfile=pylintrc path/to/your_module
#
# Pure-pip alternative (no Odoo source needed): `pip install pylint-odoo` and
# replace the three _odoo_checker_* plugins below with `pylint_odoo`.

[MAIN]
# Make Odoo's own checker modules importable (mirrors test_pylint.py, which
# adds odoo/addons/test_lint/tests to PYTHONPATH). No-op if odoo isn't found,
# so the manual PYTHONPATH route above still works.
init-hook=
    import os, sys
    try:
        import odoo
        sys.path.insert(0, os.path.join(os.path.dirname(odoo.__file__), "addons", "test_lint", "tests"))
    except Exception:
        pass

# bad_builtin is a stock pylint extension; the _odoo_checker_* are Odoo's own.
load-plugins=
    pylint.extensions.bad_builtin,
    _odoo_checker_sql_injection,
    _odoo_checker_gettext,
    _odoo_checker_unlink_override

[MESSAGES CONTROL]
# Exactly the set test_pylint.py enables.
disable=all
enable=
    used-before-assignment,
    undefined-variable,
    eval-used,
    unreachable,
    function-redefined,
    bad-builtin,
    deprecated-module,
    sql-injection,
    gettext-variable,
    gettext-placeholders,
    gettext-repr,
    raise-unlink-override

[DEPRECATED_BUILTINS]
bad-functions=input

[IMPORTS]
# csv/urllib/cgi + Odoo's SUPPORTED_DEBUGGER (pdb, ipdb, pudb, q).
deprecated-modules=csv,urllib,cgi,pdb,ipdb,pudb,q

[REPORTS]
reports=no
score=no
msg-template={path}:{line}: [{msg_id}] {symbol}: {msg}
